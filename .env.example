# Optional in all modes. If empty, GitHub API falls back to the unauthenticated rate limit.
GITHUB_TOKEN=

# Optional for arXiv repo discovery and single-paper relation HF fallback. If empty, HF exact discovery and relation fallback are unavailable.
HUGGINGFACE_TOKEN=

# Optional in CSV / URL / Notion modes. Default: retry a cached no-repo paper after 7 days.
HF_EXACT_NO_REPO_RECHECK_DAYS=7

# Optional for single-paper arXiv relation mode. If empty, OpenAlex runs without an API key.
OPENALEX_API_KEY=

# Optional for single-paper arXiv relation mode. Default: retry a cached no-arXiv relation lookup after 30 days.
ARXIV_RELATION_NO_ARXIV_RECHECK_DAYS=30

# Required only for Notion mode.
NOTION_TOKEN=
DATABASE_ID=
